name: Build Zig

on:
  workflow_dispatch:
    inputs:
      tool_name:
        description: 'Tên thư mục (Ví dụ: _template)'
        required: true
        type: string

jobs:
  build:
    runs-on: windows-latest
    defaults:
      run:
        working-directory: ./zig-tools

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Zig Compiler
        uses: goto-bus-stop/setup-zig@v2
        with:
          version: 0.15.2  # CẬP NHẬT: Sử dụng phiên bản mới nhất bạn đã kiểm chứng

      - name: Build ReleaseFast
        shell: pwsh
        run: |
          $toolName = "${{ inputs.tool_name }}"
          cd $toolName

          # Lệnh build giữ nguyên
          zig build -Doptimize=ReleaseFast -Dtarget=x86_64-windows

      - name: Prepare Artifact
        shell: pwsh
        run: |
          $toolName = "${{ inputs.tool_name }}"
          New-Item -ItemType Directory -Force -Path "dist" | Out-Null

          $sourcePath = "$toolName/zig-out/bin/*.exe"
          $exeFile = Get-ChildItem $sourcePath | Select-Object -First 1

          if ($exeFile) {
             Write-Host "Found EXE: $($exeFile.Name)"
             Copy-Item $exeFile.FullName -Destination "dist/$toolName.exe"
          } else {
             Write-Error "Build failed! No EXE found in $sourcePath"
             exit 1
          }

      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: ${{ inputs.tool_name }}_zig
          path: zig-tools/dist/*.exe
          if-no-files-found: error